<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#111"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#000"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop"
            android:src="@drawable/logo"/>

    </LinearLayout>

    <!-- MENU CATEGORIE -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/barra_categoria"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:orientation="horizontal"
            android:padding="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView android:textColor="#FFFFFF" android:padding="10dp" android:background="#333" android:layout_width="200px" android:layout_height="200px" android:text="Motore"/>
            <TextView android:textColor="#FFFFFF" android:padding="10dp" android:background="#333" android:layout_width="200px" android:layout_height="200px" android:text="Scarichi"/>


        </LinearLayout>
    </HorizontalScrollView>

    <!-- TITOLO -->
    "/>

    <!-- GRID -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="200px"
        android:padding="12dp"
        android:text="Componenti Motore Disponibili"
        android:textColor="#FFF"
        android:textSize="18sp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>