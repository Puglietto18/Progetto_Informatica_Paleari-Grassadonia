<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true"
    tools:context=".DettaglioProdottoActvity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <Button
            android:id="@+id/pulsanteBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/barra_categoria"
            android:text="Torna indietro"
            android:textAllCaps="false"
            android:textColor="@color/white"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:backgroundTint="@color/black"
            android:elevation="6dp">
            <ImageView
                android:id="@+id/fotoProdotto"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                tools:src="@drawable/cilindro_yz_85"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/testoProdotto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="@color/white"
            android:textSize="28dp"
            android:textStyle="bold"
            android:layout_marginLeft="105dp"
            tools:text="Cilindro yz 85"/>

        <TextView
            android:id="@+id/descrizioneProdotto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="19dp"
            android:layout_marginTop="20dp"
            tools:text="Cilindro in alluminio da 84.7 cc progettato per migliorare prestazioni e dissipazione del calore. Ottimo upgrade per aumentare potenza e affidabilità."/>

        <TextView
            android:id="@+id/prezzoProdotto"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textColor="@color/white"
            android:textSize="19dp"
            android:layout_marginTop="20dp"
            tools:text="PREZZO: 464€"/>

        <Button
            android:id="@+id/pulsanteCarrello"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:backgroundTint="@color/barra_categoria"
            android:textSize="18dp"
            android:textColor="@color/white"
            tools:text="AGGIUNGI AL CARRELLO"/>


    </LinearLayout>
</ScrollView>